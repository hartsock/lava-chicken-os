[Desktop Entry]
Type=Application
Name=nugget
GenericName=Your AI agent
Comment=Talk to nugget — your personal lava-chicken AI agent (runs as you)
# Launches newt AS THE CURRENT USER (bounded by their own permissions, no root).
# Path is rewritten to /var/lib/... on SteamOS at install.
Exec=konsole --hide-menubar -e /usr/bin/nugget
Icon=nugget
Terminal=false
Categories=Utility;System;
Keywords=nugget;agent;ai;newt;
