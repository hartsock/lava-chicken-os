// Let a locally-logged-in human in group 'wheel' run the one-time nugget-tui
// grant. Prompts once, then remembers (AUTH_SELF_KEEP) so the button is
// frictionless afterward. Installed to /etc/polkit-1/rules.d/.
polkit.addRule(function(action, subject) {
  if (action.id == "org.freedesktop.policykit.exec" &&
      action.lookup("program") == "/usr/libexec/nugget-grant-tui" &&
      subject.local && subject.active && subject.isInGroup("wheel")) {
    return polkit.Result.AUTH_SELF_KEEP;
  }
});
