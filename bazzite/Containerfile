# lava-chicken-os — custom Bazzite bootc image.
# Bakes the SYSTEM layer only (sshd config, first-boot unit, shared payload).
# Per-user $HOME provisioning (SSH keys, newt persona, user services) happens on
# the running machine via lava-chicken-firstboot.service — see docs/REMOTE-DAYZERO.md.

FROM ghcr.io/ublue-os/bazzite:stable
# VERIFY: KDE desktop / AMD is the default 'bazzite' image; confirm the tag/variant.

# Public GitHub username whose keys seed SSH access. No secrets — just a handle.
ARG LAVA_GITHUB_USER=hartsock
# Box + agent name (default nugget; setup may change it, e.g. kajiblet).
ARG LAVA_BOX_NAME=nugget

# 1. Drop the system files into the image rootfs (system_files/ mirrors real
#    rootfs paths). CI syncs ../common -> system_files/usr/share/lava-chicken
#    BEFORE build, so the single-source-of-truth payload lands under
#    /usr/share/lava-chicken (that synced dir is gitignored, not committed).
COPY system_files/ /

# 2. Build-time enablement.
COPY build.sh /tmp/build.sh
RUN LAVA_GITHUB_USER="${LAVA_GITHUB_USER}" LAVA_BOX_NAME="${LAVA_BOX_NAME}" /tmp/build.sh && \
    rm -f /tmp/build.sh && \
    ostree container commit
# VERIFY: modern bootc images may prefer `bootc container lint` over
# `ostree container commit`; confirm against current uBlue template.
