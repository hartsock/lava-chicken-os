#!/usr/bin/env bash
# LaCOS — Lava Chicken OS control command. One friendly branded entrypoint for
# the box: status, attach the resident nugget agent, drive the agent, version.
set -euo pipefail
VERSION_FILE=/etc/lava-chicken/version
STATE=/var/lib/lava-chicken

ver() { cat "$VERSION_FILE" 2>/dev/null || echo "?"; }

find_bin() {  # locate a helper: baked (/usr/share) on Bazzite, /var on SteamOS
  local d
  for d in /usr/share/lava-chicken/bin "$STATE/bin"; do
    [ -x "$d/$1" ] && { echo "$d/$1"; return 0; }
  done
  command -v "$1" 2>/dev/null || return 1
}

# uupd (the auto-updater) can hold the rpm-ostree transaction lock ("System
# transaction in progress"). Pause its timer + service around any real bootc
# transaction (upgrade / mode / channel) so it can't re-grab the lock mid-switch;
# re-arm the timer after so background auto-updates aren't left off.
pause_autoupdate()  { echo "  (pausing the auto-updater so it doesn't clash)"; systemctl stop  uupd.timer uupd.service 2>/dev/null || true; }
resume_autoupdate() { systemctl start uupd.timer 2>/dev/null || true; }

# Parse the booted bootc image ref into "BASE VARIANT CHANNEL", e.g.
#   ghcr.io/hartsock/lava-chicken-os stable unstable
# variant = stable|deck (desktop|Game-Mode); channel is one of:
#   unstable  bare :stable / :deck tag        (rolling; every merge)
#   stable    :stable-release / :deck-release (moved only on a release)
#   pinned    :stable-<ver> / :deck-<ver>     (an immutable release pin — DON'T move it silently)
#   unknown   a ref we don't recognize (a fork's custom tag)
# The variant is matched against a KNOWN SET, not string-stripped, so the immutable
# :<variant>-<version> pins that release.yml creates are recognized as pins (not
# misread as a bogus variant that `mode`/`channel` would then rewrite the box onto).
box_ref() {
  local img base tag variant channel
  img="$(bootc status --format json 2>/dev/null | python3 -c 'import json,sys; print(json.load(sys.stdin)["status"]["booted"]["image"]["image"]["image"])' 2>/dev/null)" || return 1
  [ -n "$img" ] || return 1
  img="${img%%@*}"; base="${img%:*}"; tag="${img##*:}"
  case "$tag" in
    stable)         variant=stable; channel=unstable ;;
    deck)           variant=deck;   channel=unstable ;;
    stable-release) variant=stable; channel=stable ;;
    deck-release)   variant=deck;   channel=stable ;;
    stable-*)       variant=stable; channel=pinned ;;
    deck-*)         variant=deck;   channel=pinned ;;
    *)              variant="$tag"; channel=unknown ;;
  esac
  printf '%s %s %s\n' "$base" "$variant" "$channel"
}

usage() {
  cat <<EOF
LaCOS $(ver) — Lava Chicken OS  🐔🌋
usage: lacos <command>
  status        services + resident agent + version
  mode          show boot mode; 'sudo lacos mode console|desktop' switches it
                (console = Game Mode like a Steam Deck; desktop = normal desktop)
  attach        attach the resident nugget agent session (the "nugget" button)
  agent <cmd>   pause|resume|disable|kill|status the agent (wraps nugget-agentctl)
  setup         run the 2nd-boot setup wizard (name, Tailscale, home DNS, ...)
  doctor        check the box end-to-end; 'sudo lacos doctor --fix' repairs
  upgrade       fetch the latest OS: 'sudo lacos upgrade' stages it (reboot later),
                --now stages + reboots, --check just looks
  channel       show/switch update channel: 'sudo lacos channel stable|unstable'
                (stable = tested releases only; unstable = every change from main)
  models        pull/refresh the LLM models (qwen2.5-coder + embeddings)
  apps          install/refresh the creative + gaming Flatpak apps
  version       print the OS version
  help          this help
EOF
}

case "${1:-help}" in
  status)
    echo "LaCOS $(ver) — host $(hostname)"
    for u in nugget-agent-tmux.service ollama.service sshd.service \
             lava-chicken-boot-sound.service; do
      printf '  %-30s %s\n' "$u" "$(systemctl is-active "$u" 2>/dev/null || echo unknown)"
    done
    if [ -S /run/nugget/tmux.sock ]; then echo "  nugget session               LIVE"
    else echo "  nugget session               absent"; fi
    v="$(cat /usr/share/lava-chicken/variant 2>/dev/null || echo '?')"
    case "$v" in deck) echo "  boot mode                    console (Game Mode)";;
                 stable) echo "  boot mode                    desktop";; esac
    if [ -s /var/lib/lava-chicken/firstboot.failed-steps ]; then
      echo "  !! provisioning steps FAILED: $(tr '\n' ' ' < /var/lib/lava-chicken/firstboot.failed-steps)"
      echo "     re-run each: sudo bash /usr/share/lava-chicken/provision/<step>"
    fi
    ;;
  mode)
    # Parent-friendly wrapper around `bootc switch` (#23): pick what the box
    # boots into, by name, without knowing registries or tags.
    shift
    cur="$(cat /usr/share/lava-chicken/variant 2>/dev/null || echo unknown)"
    case "$cur" in deck) curname="console (Game Mode)";; stable) curname=desktop;; *) curname="$cur";; esac
    if [ $# -eq 0 ]; then
      echo "Current mode: $curname"
      echo "Switch with:  sudo lacos mode console    (boots straight into Game Mode, like a Steam Deck)"
      echo "         or:  sudo lacos mode desktop    (boots to the normal desktop)"
      exit 0
    fi
    case "$1" in
      console|deck|game|gamemode) want=deck;  wantname="console (Game Mode)";;
      desktop|stable)             want=stable; wantname="desktop";;
      *) echo "unknown mode '$1' — use: console or desktop" >&2; exit 2;;
    esac
    command -v bootc >/dev/null 2>&1       || { echo "mode switching needs the bootc-based (Bazzite) image; this box doesn't have bootc." >&2; exit 1; }
    if [ "$want" = "$cur" ]; then echo "Already in $wantname mode — nothing to do."; exit 0; fi
    [ "$(id -u)" = 0 ] || { echo "This needs admin rights — run:  sudo lacos mode $1"; exit 1; }
    # Derive base + CURRENT CHANNEL from what's booted, so a forked registry keeps
    # working AND switching variant preserves the channel (mode x channel compose:
    # a stable-channel box stays on the stable channel across a mode switch).
    ref="$(box_ref)" || { echo "could not read the booted image from bootc status" >&2; exit 1; }
    read -r base _ channel <<<"$ref"
    case "$channel" in
      unstable) newtag="$want" ;;
      stable)   newtag="${want}-release" ;;
      *) echo "This box is pinned to a specific release, not a rolling channel, so I won't silently move it to a different image." >&2
         echo "Pick a channel first, then switch mode:  sudo lacos channel unstable   (or: stable)" >&2
         exit 1 ;;
    esac
    echo "Switching to $wantname mode  ->  ${base}:${newtag}"
    pause_autoupdate
    if bootc switch "${base}:${newtag}"; then
      resume_autoupdate
      echo
      echo "Done. The new mode takes effect on the next restart:"
      echo "  systemctl reboot        (or just use the power menu)"
      echo "Changed your mind? 'sudo lacos mode ${curname%% *}' switches back the same way."
      echo "(Restart before changing mode or channel again, so the switches don't stack.)"
    else
      resume_autoupdate
      echo "Couldn't switch to ${base}:${newtag} — a transient network/registry error can cause this. Try again in a moment." >&2
      exit 1
    fi
    ;;
  attach)
    if a="$(find_bin attach-nugget)"; then exec "$a"
    else echo "attach-nugget not found" >&2; exit 1; fi
    ;;
  agent)
    shift
    if c="$(find_bin nugget-agentctl)"; then exec sudo "$c" "$@"
    else echo "nugget-agentctl not found" >&2; exit 1; fi
    ;;
  models)
    shift
    if m="$(find_bin lacos-pull-models)"; then exec "$m" "$@"
    else echo "lacos-pull-models not found" >&2; exit 1; fi
    ;;
  apps)
    shift
    if a="$(find_bin lacos-install-apps)"; then exec "$a" "$@"
    else echo "lacos-install-apps not found" >&2; exit 1; fi
    ;;
  setup)
    shift
    if s="$(find_bin lacos-setup)"; then exec "$s" "$@"
    else echo "lacos-setup not found" >&2; exit 1; fi
    ;;
  doctor)
    shift
    if d="$(find_bin lacos-doctor)"; then exec "$d" "$@"
    else echo "lacos-doctor not found" >&2; exit 1; fi
    ;;
  upgrade|update)
    # Parent-friendly wrapper around `bootc upgrade` — fetch the newest LaCOS
    # image without anyone needing to know bootc or uupd. Defaults to STAGE (no
    # reboot) so it never yanks the box out from under a kid mid-game; --now
    # reboots, --check just looks. Pairs with doctor: upgrade -> reboot -> doctor.
    shift; sub="${1:-}"
    command -v bootc >/dev/null 2>&1 || { echo "Upgrades need the bootc-based (Bazzite) image; this box doesn't have bootc." >&2; exit 1; }
    [ "$(id -u)" = 0 ] || { echo "Upgrades need admin rights — run:  sudo lacos upgrade${sub:+ $sub}"; exit 1; }
    ch="$(box_ref 2>/dev/null | awk '{print $3}')" || ch=""
    case "$ch" in
      unstable) echo "Channel: unstable (every change from main). Once the project cuts a tested release:  sudo lacos channel stable" ;;
      stable)   echo "Channel: stable (tested releases only)." ;;
      pinned)   echo "Channel: pinned to a specific release — upgrades won't move it. Follow a channel again:  sudo lacos channel stable   (or: unstable)" ;;
    esac
    # pause_autoupdate/resume_autoupdate are defined near the top (shared with
    # mode/channel). --check is read-only and never pauses the auto-updater.
    reboot_hint() {
      echo "Downloaded — it takes effect on the NEXT restart. Reboot when no one is mid-game:"
      echo "  systemctl reboot        (or the power menu; or:  sudo lacos upgrade --now)"
      echo "After it reboots, confirm the box is healthy:  lacos doctor"
    }
    case "$sub" in
      --check|check)
        echo "Checking for a newer Lava Chicken OS ..."
        bootc upgrade --check || true   # may exit non-zero to signal "update available"
        ;;
      --now|--apply)
        echo "Applying the latest Lava Chicken OS — the box restarts if an update is pending ..."
        pause_autoupdate
        # --apply reboots when something is staged (killing us here); if it
        # returns, nothing was pending — re-arm auto-update either way.
        bootc upgrade --apply || { rc=$?; resume_autoupdate; exit "$rc"; }
        resume_autoupdate
        echo "Already up to date — nothing to apply. 🐔"
        ;;
      ''|--stage|stage)
        echo "Downloading the latest Lava Chicken OS (this can take a few minutes) ..."
        pause_autoupdate
        bootc upgrade || { rc=$?; resume_autoupdate; exit "$rc"; }
        resume_autoupdate
        staged="$(bootc status --format json 2>/dev/null | python3 -c 'import json,sys; s=json.load(sys.stdin); print("y" if (s.get("status") or {}).get("staged") else "n")' 2>/dev/null || echo '?')"
        echo
        # Only claim "up to date" on a CONFIRMED no-stage; y or '?' (couldn't
        # tell) -> assume pending and tell them to reboot, never a false all-clear.
        if [ "$staged" = n ]; then echo "Already up to date. 🐔"; else reboot_hint; fi
        ;;
      *) echo "usage: sudo lacos upgrade [--check | --now]   (no flag = download now, reboot later)" >&2; exit 2 ;;
    esac
    ;;
  channel)
    # A channel = which image ref the box tracks. unstable = the continuous
    # :stable/:deck tags (every merge); stable = :stable-release/:deck-release,
    # moved only when a GitHub release is cut. `lacos upgrade` tracks whatever ref
    # we're on, so switching channel is a one-time `bootc switch`, like `mode`.
    shift
    command -v bootc >/dev/null 2>&1 || { echo "Channels need the bootc-based (Bazzite) image; this box doesn't have bootc." >&2; exit 1; }
    # Read-only "which channel?" must work even if bootc status hiccups.
    if ref="$(box_ref)"; then read -r base variant cur <<<"$ref"; else base=""; variant=""; cur=unknown; fi
    if [ $# -eq 0 ]; then
      echo "Current channel: $cur"
      echo "  stable   — only tested, released versions (recommended for the family box)"
      echo "  unstable — every change straight from main (bleeding edge)"
      [ "$cur" = pinned ] && echo "  (pinned to a specific release right now; switching picks up a rolling channel again)"
      echo "Switch with:  sudo lacos channel stable      (or: unstable)"
      exit 0
    fi
    [ -n "$base" ] || { echo "could not read the booted image from bootc status — can't switch channel" >&2; exit 1; }
    [ "$cur" = unknown ] && { echo "I don't recognize this box's image ref, so I won't guess a channel for it." >&2; exit 1; }
    case "$1" in
      stable)             want=stable;   newtag="${variant}-release";;
      unstable|edge|main) want=unstable; newtag="${variant}";;
      *) echo "unknown channel '$1' — use: stable or unstable" >&2; exit 2;;
    esac
    if [ "$want" = "$cur" ]; then echo "Already on the $want channel — nothing to do."; exit 0; fi
    [ "$(id -u)" = 0 ] || { echo "This needs admin rights — run:  sudo lacos channel $1"; exit 1; }
    echo "Switching to the $want channel  ->  ${base}:${newtag}"
    pause_autoupdate
    if bootc switch "${base}:${newtag}"; then
      resume_autoupdate
      echo
      echo "Done. From now on 'lacos upgrade' pulls $want images. Takes effect on the next restart:"
      echo "  systemctl reboot        (or:  sudo lacos upgrade --now)"
      case "$cur" in stable|unstable) echo "Changed your mind? 'sudo lacos channel $cur' switches back.";; esac
      echo "(Restart before changing mode or channel again, so the switches don't stack.)"
    else
      resume_autoupdate
      echo "Couldn't switch to ${base}:${newtag}." >&2
      [ "$want" = stable ] && echo "The stable channel may have no release yet — check the project's Releases page, then try again." >&2
      exit 1
    fi
    ;;
  version) ver ;;
  help|-h|--help) usage ;;
  *) usage; exit 2 ;;
esac
