# Canonical Sunshine port list. Single source of truth for firewall rules.
# Lifted from my_home/docs/runbooks/sunshine-moonlight-gnuc.md (Phase 4).
SUNSHINE_TCP_PORTS="47984 47989 47990 48010"
SUNSHINE_UDP_PORTS="47998 47999 48000 48002"

# Trusted sources allowed to reach Sunshine:
#   home LAN + WireGuard subnet (network-topology.md: 10.10.0.0/24).
SUNSHINE_ALLOW_CIDRS="192.168.0.0/24 10.10.0.0/24"
