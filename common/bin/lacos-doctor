#!/usr/bin/env bash
# lacos doctor — on-box diagnose (+ repair with --fix). Issue #35, born on
# hardware day when provisioning broke and the recovery script lived in /tmp
# (tmpfs ate it on reboot). This is that recovery, permanent and generalized.
#
#   lacos doctor          check everything, PASS/WARN/FAIL report (safe, no sudo)
#   sudo lacos doctor --fix   re-run the idempotent remedies for whatever failed
#
# Every remedy is one of the numbered provision steps (all idempotent) or a
# service enable — the same things a clean first boot does.
set -u
PAY=/usr/share/lava-chicken
STATE=/var/lib/lava-chicken
[ -d "$PAY/provision" ] || PAY="$STATE"          # SteamOS staging fallback
[ -r /etc/lava-chicken/site.conf ] && . /etc/lava-chicken/site.conf  # LAVA_KID_USERS
FIX=0; [ "${1:-}" = "--fix" ] && FIX=1
if [ "$FIX" = 1 ] && [ "$(id -u)" != 0 ]; then
  echo "--fix needs admin rights:  sudo lacos doctor --fix"; exit 1
fi

declare -a REPORT=() REMEDIES=()
note() { REPORT+=("$1"); }                       # "PASS ..." / "WARN ..." / "FAIL ..."
remedy() { REMEDIES+=("$1"); }                   # commands run under --fix (deduped)
provision() { timeout --signal=TERM --kill-after=30 300 bash "$PAY/provision/$1"; }

# ── checks ────────────────────────────────────────────────────────────────────
# 1. first-boot provisioning
if [ -f "$STATE/firstboot.done" ]; then
  if [ -s "$STATE/firstboot.failed-steps" ]; then
    note "FAIL first-boot finished with failed steps: $(tr '\n' ' ' < "$STATE/firstboot.failed-steps")"
    while read -r st; do [ -n "$st" ] && remedy "provision $st"; done < "$STATE/firstboot.failed-steps"
  else
    note "PASS first-boot provisioning complete"
  fi
else
  note "FAIL first-boot provisioning never completed"
  remedy "rerun-firstboot"
fi

# 2. core services
for svc in sshd ollama nugget-agent-tmux lava-chicken-boot-sound; do
  st="$(systemctl is-active "$svc.service" 2>/dev/null || true)"
  en="$(systemctl is-enabled "$svc.service" 2>/dev/null || true)"
  case "$svc:$st" in
    sshd:active|ollama:active|nugget-agent-tmux:active) note "PASS $svc active" ;;
    lava-chicken-boot-sound:*)  # oneshot: enabled matters, active does not
      [ "$en" = enabled ] && note "PASS boot chime enabled" \
        || { note "FAIL boot chime not enabled"; remedy "enable lava-chicken-boot-sound.service"; } ;;
    *) note "FAIL $svc is $st (${en:-unknown})"
       remedy "enable-start $svc.service" ;;
  esac
done

# 3. ollama really answering (the agent's lifeline)
if command -v ollama >/dev/null 2>&1; then
  if curl -fsS --max-time 3 http://127.0.0.1:11434/api/version >/dev/null 2>&1; then
    note "PASS ollama answering on loopback"
  else
    note "FAIL ollama installed but not answering on 127.0.0.1:11434"
    remedy "enable-start ollama.service"
  fi
else
  note "FAIL ollama not installed (image too old? 'bootc upgrade' gets the baked one)"
  remedy "hint-bootc-upgrade"
fi

# 4. newt + per-user agent kit (persona / skills for the invoking human)
[ -x "$STATE/bin/newt" ] && note "PASS newt installed (shared)" \
  || { note "FAIL newt missing"; remedy "provision 50-nugget-agent.sh"; }
H="${SUDO_USER:+/var/home/$SUDO_USER}"; H="${H:-${HOME:-/root}}"   # set -u safe: HOME may be unset
if [ -f "$H/.newt/personas/nugget.md" ] && [ -d "$H/.newt/skills" ]; then
  note "PASS persona + skills present for $(basename "$H")"
else
  note "FAIL persona/skills missing for $(basename "$H")"
  remedy "provision 45-nugget-tmux.sh"
fi

# 5. splash + suspend + models
theme="$(plymouth-set-default-theme 2>/dev/null || echo none)"
[ "$theme" = lava-chicken ] && note "PASS boot splash theme set" \
  || { note "FAIL boot splash theme is '$theme' (want lava-chicken)"; remedy "provision 07-plymouth.sh"; }
# The theme only DRAWS if graphical boot is enabled on the kernel cmdline (rhgb).
# Without it, boot is a black screen until the greeter — theme set but never shown
# (real-hardware finding). Fixable via rpm-ostree kargs (takes effect next boot).
if [ -r /proc/cmdline ] && ! grep -qw rhgb /proc/cmdline; then
  note "FAIL boot splash won't draw — kernel cmdline lacks 'rhgb' (dark boot until greeter)"
  remedy "splash-karg"
else
  note "PASS graphical boot enabled (rhgb on cmdline)"
fi
if [ "$(readlink /etc/systemd/system/suspend.target 2>/dev/null)" = /dev/null ]; then
  note "PASS auto-suspend masked (always-on box)"
else
  note "FAIL auto-suspend NOT masked — the box can sleep mid-stream / mid-provisioning"
  remedy "mask-suspend"
fi
# The agent is useless without its models. Require the CONFIGURED set (models.conf
# else the default chat+embeddings pair) — not just "any model" — and make missing
# models a FIXABLE fault: `sudo lacos doctor --fix` pulls them (idempotent).
if command -v ollama >/dev/null 2>&1; then
  want="$(grep -vE '^[[:space:]]*(#|$)' /etc/lava-chicken/models.conf 2>/dev/null | tr '\n' ' ')"
  [ -n "${want// /}" ] || want="qwen2.5-coder:7b nomic-embed-text"
  have="$(ollama list 2>/dev/null | awk 'NR>1{print $1}')"
  missing=""
  for m in $want; do printf '%s\n' "$have" | grep -q "^${m%%:*}" || missing="$missing $m"; done
  if [ -n "${missing# }" ]; then
    note "FAIL missing LLM models:$missing — the agent can't answer without them"
    remedy "pull-models"
  else
    note "PASS LLM models present ($want)"
  fi
fi

# 7. kids must stay unprivileged — never in wheel (sudo) or nugget-tui (resident
# agent). The KDE Users panel's "Administrator" toggle silently re-adds kids to
# wheel after 30-users removed them (#53); catch + repair that here.
in_group() { getent group "$2" 2>/dev/null | cut -d: -f4 | tr ',' '\n' | grep -qx "$1"; }
for kid in ${LAVA_KID_USERS:-}; do
  getent passwd "$kid" >/dev/null 2>&1 || continue
  if in_group "$kid" wheel; then
    note "FAIL kid '$kid' is in wheel (admin/sudo) — must be unprivileged"
    remedy "drop-kid-priv $kid"
  elif in_group "$kid" nugget-tui; then
    note "FAIL kid '$kid' can attach the resident nugget agent (nugget-tui)"
    remedy "drop-kid-priv $kid"
  else
    note "PASS kid '$kid' unprivileged (no wheel, no nugget-tui)"
  fi
done

# 8. Steam home ownership — a root-owned ~/.steam blocks Steam from creating the
# ~/.steam/steam symlink, so the client never opens (real-hardware finding: a
# root-run provision step created it before the user first launched Steam; a
# stray `sudo steam` does the same). Only assert what we can actually
# stat: as root (sudo lacos doctor) every home is visible; as a normal user the
# 0700 homes of OTHERS are unreadable and correctly skipped. Repair touches ONLY
# ~/.steam — never the whole home (rootless-podman subuid storage lives under it
# and a recursive chown would corrupt it).
while IFS=: read -r uname _ uid _ _ uhome _; do
  [ "$uid" -ge 1000 ] && [ "$uid" -lt 65000 ] && [ -d "$uhome/.steam" ] || continue
  owner="$(stat -c %U "$uhome/.steam" 2>/dev/null)" || continue
  [ -n "$owner" ] || continue
  if [ "$owner" != "$uname" ]; then
    note "FAIL $uname's ~/.steam is owned by '$owner', not $uname — Steam can't start"
    remedy "fix-steam-home $uname"
  fi
done < <(getent passwd)

# 9. login wallpaper — if the LaCOS login art is available (baked in /usr, or
# staged in /var) the plasmalogin greeter should use it, not the stock Bazzite
# background (real-hardware finding). Only assert when both plasmalogin AND the
# art are present; otherwise there is nothing to enforce.
login_art=""
for a in /usr/share/lava-chicken/brand/lava_chicken_os_login.png \
         /var/lib/lava-chicken/brand/lava_chicken_os_login.png; do
  [ -f "$a" ] && { login_art="$a"; break; }
done
if [ -d /usr/lib/plasmalogin ] && [ -n "$login_art" ]; then
  if grep -rqs "lava_chicken_os_login" /etc/plasmalogin.conf /etc/plasmalogin.conf.d 2>/dev/null; then
    note "PASS login wallpaper set to the LaCOS art"
  else
    note "FAIL login screen using the stock wallpaper, not the LaCOS art"
    remedy "login-wallpaper"
  fi
fi

# 10. context lines (never fail)
note "INFO boot mode: $(cat /usr/share/lava-chicken/variant 2>/dev/null || echo '?') · disk free: $(df -h /var 2>/dev/null | awk 'NR==2{print $4}')"

# ── report ────────────────────────────────────────────────────────────────────
echo "lacos doctor — $(hostname) — LaCOS $(cat /etc/lava-chicken/version 2>/dev/null || echo '?')"
printf '  %s\n' "${REPORT[@]}"
fails=$(printf '%s\n' "${REPORT[@]}" | grep -c '^FAIL') || true

if [ "$FIX" != 1 ]; then
  if [ "${fails:-0}" -gt 0 ]; then
    echo; echo "$fails problem(s). Repair with:  sudo lacos doctor --fix"
    exit 1
  fi
  echo; echo "All good. 🐔"; exit 0
fi

# ── repair (--fix) ────────────────────────────────────────────────────────────
[ "${fails:-0}" -eq 0 ] && { echo; echo "Nothing to fix. 🐔"; exit 0; }
echo; echo "── repairing ──"
mapfile -t todo < <(printf '%s\n' "${REMEDIES[@]}" | awk '!seen[$0]++')
rc=0
for r in "${todo[@]}"; do
  echo "==> $r"
  case "$r" in
    provision\ *)        provision "${r#provision }" || rc=1 ;;
    rerun-firstboot)     rm -f "$STATE/firstboot.done" "$STATE/firstboot.failed-steps"
                         provision firstboot.sh || rc=1 ;;
    enable\ *)           systemctl enable "${r#enable }" || rc=1 ;;
    enable-start\ *)     u="${r#enable-start }"
                         systemctl enable "$u" 2>/dev/null
                         systemctl reset-failed "$u" 2>/dev/null
                         systemctl start --no-block "$u" || rc=1 ;;
    mask-suspend)        systemctl mask sleep.target suspend.target hibernate.target hybrid-sleep.target || rc=1 ;;
    drop-kid-priv\ *)    k="${r#drop-kid-priv }"
                         gpasswd -d "$k" wheel      2>/dev/null
                         gpasswd -d "$k" nugget-tui 2>/dev/null
                         echo "    revoked admin + resident-agent for $k (don't re-enable 'Administrator' in KDE Users)" ;;
    fix-steam-home\ *)   u="${r#fix-steam-home }"; h="$(getent passwd "$u" | cut -d: -f6)"
                         # ONLY ~/.steam — never the whole home (subuid container storage).
                         [ -n "$h" ] && [ -d "$h/.steam" ] && chown -R "$u" "$h/.steam" \
                           && echo "    reclaimed $h/.steam for $u — relaunch Steam" || rc=1 ;;
    pull-models)         m="$PAY/bin/lacos-pull-models"; [ -x "$m" ] || m="$STATE/bin/lacos-pull-models"
                         echo "    pulling the configured model set (~5 GB; idempotent)…"
                         "$m" || rc=1 ;;
    splash-karg)         if command -v rpm-ostree >/dev/null 2>&1; then
                           if rpm-ostree kargs --append-if-missing=rhgb --append-if-missing=splash; then
                             echo "    rhgb/splash added — REBOOT to see the boot splash"
                           else
                             echo "    rpm-ostree busy? release it:  sudo systemctl stop uupd.service  then re-run --fix"; rc=1
                           fi
                         else echo "    no rpm-ostree — add 'rhgb splash' to the kernel cmdline manually"; rc=1; fi ;;
    login-wallpaper)     src=/usr/share/lava-chicken/brand/lava_chicken_os_login.png
                         [ -f "$src" ] || src=/var/lib/lava-chicken/brand/lava_chicken_os_login.png
                         dst=/var/lib/lava-chicken/brand/lava_chicken_os_login.png   # greeter-readable (/usr is immutable)
                         install -D -m0644 "$src" "$dst" 2>/dev/null
                         touch /etc/plasmalogin.conf
                         sed -i "/# >>> lava-chicken login >>>/,/# <<< lava-chicken login <<</d" /etc/plasmalogin.conf 2>/dev/null || true
                         printf '\n# >>> lava-chicken login >>>\n[Greeter]\nWallpaperPlugin=org.kde.image\n\n[Greeter][Wallpaper][org.kde.image][General]\nImage=file://%s\nPreviewImage=file://%s\n# <<< lava-chicken login <<<\n' "$dst" "$dst" >> /etc/plasmalogin.conf \
                           && echo "    login wallpaper set — shows at the next login screen" || rc=1 ;;
    hint-bootc-upgrade)  echo "    ollama arrives baked with:  sudo bootc upgrade && systemctl reboot" ;;
  esac
done
echo; echo "── done (rc=$rc) — re-check: lacos doctor ──"
exit "$rc"
