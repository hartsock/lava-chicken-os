# user-supplied media never gets committed
assets/user/*
!assets/user/README.md

# belt & suspenders: block media formats repo-wide
*.mp3
*.m4a
*.ogg
*.opus
*.wav
*.flac
*.webm
*.mp4
*.mkv

# ...EXCEPT the owner's ORIGINAL boot media, which ships with the OS
!assets/brand/boot-sound.wav
!assets/brand/boot-movie.webm

# generated wallpapers are recreated locally
assets/generated/out/

# CI-synced payload (common/ is the source of truth; this is generated)
bazzite/system_files/usr/share/lava-chicken/

# junk
.DS_Store
*.log
