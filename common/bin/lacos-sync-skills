#!/usr/bin/env bash
# lacos-sync-skills — distribute LaCOS's bundled newt skills to /etc/skel and
# every real user's ~/.newt/skills.
#
# VERSION-GATED: it only redistributes when the image version changed since the
# last sync, so running it on every boot is cheap AND it closes the upgrade gap —
# new or updated skills baked into a fresh image reach EXISTING users on the next
# boot, not just on a clean install (first-boot 45-nugget-tmux.sh seeds them;
# bootc upgrades don't re-run it). Idempotent.
#
# Run by lava-chicken-skills.service (every boot) and by `lacos doctor --fix`.
#   lacos-sync-skills           sync if the image version changed since last time
#   lacos-sync-skills --force   sync regardless of the version stamp
set -u
PAY=/usr/share/lava-chicken
STATE=/var/lib/lava-chicken
[ -d "$PAY/newt-skills" ] || PAY="$STATE"          # SteamOS staging fallback
SRC="$PAY/newt-skills"
STAMP="$STATE/skills-synced"
VER="$(cat /etc/lava-chicken/version 2>/dev/null || echo unknown)"
FORCE=0; [ "${1:-}" = "--force" ] && FORCE=1

[ -d "$SRC" ] || { echo "lacos-sync-skills: no skills payload at $SRC — nothing to do"; exit 0; }
[ "$(id -u)" = 0 ] || { echo "lacos-sync-skills: needs root (runs via the service, or 'sudo lacos doctor --fix')" >&2; exit 1; }

# Cheap no-op once this image version has been synced (unless forced).
if [ "$FORCE" = 0 ] && [ "$(cat "$STAMP" 2>/dev/null)" = "$VER" ]; then
  exit 0
fi

# Refresh every bundled skill into a destination ~/.newt/skills (or /etc/skel).
# Managed (image) skills track the image; a user's OWN skills (not in the payload)
# are never touched. $2 = owner ("" for skel).
sync_into() {
  local dest="$1" owner="${2:-}" sk skn
  install -d -m0755 "$dest" || return 1
  # own ~/.newt and ~/.newt/skills for a real user (leaf-only chown leaves the
  # parent root-owned — the #55 class that broke newt first-run on hardware).
  [ -n "$owner" ] && chown "$owner" "$dest" "$(dirname "$dest")" 2>/dev/null || true
  for sk in "$SRC"/*/; do
    [ -f "${sk}SKILL.md" ] || continue
    skn="$(basename "$sk")"
    rm -rf "${dest:?}/$skn"
    cp -a "${sk%/}" "$dest/$skn"
    [ -n "$owner" ] && chown -R "$owner" "$dest/$skn"
  done
}

sync_into /etc/skel/.newt/skills ""                 # future users
n=0
while IFS=: read -r uname _ uid _ _ uhome _; do
  [ "$uid" -ge 1000 ] && [ "$uid" -lt 65000 ] && [ -n "$uhome" ] && [ -d "$uhome" ] || continue
  sync_into "$uhome/.newt/skills" "$uname" && { n=$((n+1)); echo "lacos-sync-skills: synced $uname"; }
done < <(getent passwd)

install -d -m0755 "$STATE"
printf '%s\n' "$VER" > "$STAMP"
echo "lacos-sync-skills: image $VER — skills synced to $n user(s) + /etc/skel"
