# The nugget brand — single source of truth, sourced by both launchers
# (common/bin/nugget and common/bin/nugget-agent-loop) after they locate this
# dir as NEWT_BRAND_LOGO_DIR. newt reads these at runtime; no recompile.
# A downstream brand is just: this dir of <prefix>-<stem>.txt art + this file.
export NEWT_BRAND_LOGO_PREFIX=nugget
export NEWT_BRAND_NAME=nugget
export NEWT_BRAND_TAGLINE="EAT. CODE. DEPLOY. REPEAT."
