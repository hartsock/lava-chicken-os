#!/usr/bin/env bash
# Runs as root via pkexec. Adds the named human to nugget-tui and re-applies the
# live tmux server ACL — this is the ROOT-EQUIVALENT gate, done once per human
# with an auth prompt. Keep membership to humans you trust with the box.
set -euo pipefail
U="${1:?usage: nugget-grant-tui <username>}"
getent passwd "$U" >/dev/null || { echo "no such user: $U" >&2; exit 1; }

getent group nugget-tui >/dev/null || groupadd -g 971 nugget-tui
gpasswd -a "$U" nugget-tui

# Apply to the already-running server now (group change alone isn't retroactive).
systemctl start "nugget-agent-grant@${U}.service" 2>/dev/null || true
echo "Granted '$U' attach access to the nugget agent session."
