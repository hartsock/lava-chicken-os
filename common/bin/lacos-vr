#!/usr/bin/env bash
# lacos vr — get wireless VR (ALVR) working on the box, safely.
#
#   lacos vr doctor             check the VR firewall + readiness (safe, no sudo)
#   sudo lacos vr doctor --fix  repair the firewall: minimal ALVR ports, permanent,
#                               and clear any "open everything" hack
#   sudo lacos vr setup         do the firewall fix, then print the kid's next steps
#   lacos vr help
#
# ALVR streams PC VR to a wireless headset (a Meta Quest). On Linux the streamer
# needs exactly two ports reachable — firewalld ships an `alvr` service covering
# 9943-9944 tcp+udp — and NOT the "open all the ports" hack kids reach for when
# the headset won't connect. This makes the rule minimal AND permanent (survives
# reboot), and tidies up the blanket-open hack if it's there. The kid coaching
# (install ALVR, pair the headset, tune the picture) lives in the `vr-setup`
# nugget skill — ask nugget "help me set up VR". This command owns only the one
# privileged bit: the firewall.
set -u
ALVR_FLATPAK=com.valvesoftware.Steam.Utility.alvr
FW=firewall-cmd

# ── read-only firewalld probes (all work as a normal user) ──────────────────────
fw_running()        { systemctl is-active firewalld >/dev/null 2>&1; }
alvr_service_known(){ $FW --get-services 2>/dev/null | tr ' ' '\n' | grep -qx alvr; }
alvr_permanent()   { $FW --permanent --list-services 2>/dev/null | tr ' ' '\n' | grep -qx alvr; }
ports_permanent()  { $FW --permanent --list-ports 2>/dev/null | grep -qE '(^| )9943-9944/(tcp|udp)'; }
# a "blanket open" = a suspiciously huge contiguous range (the kid hack: 1025-65535).
# List them from BOTH runtime and permanent config, deduped.
blanket_ports() {
  { $FW --list-ports 2>/dev/null; $FW --permanent --list-ports 2>/dev/null; } \
    | tr ' ' '\n' | grep -E '^[0-9]+-[0-9]+/(tcp|udp)$' \
    | awk -F'[-/]' '($2 - $1) >= 1000 { print $0 }' | sort -u
}

# ── the one privileged action: make the VR firewall minimal + permanent ─────────
fix_firewall() {
  [ "$(id -u)" = 0 ] || { echo "This changes the firewall, so it needs admin rights — run:  sudo lacos vr setup" >&2; return 1; }
  local rc=0
  fw_running || { echo "  starting firewalld…"; systemctl enable --now firewalld || rc=1; }
  # Prefer the shipped `alvr` service (self-documenting); fall back to raw ports
  # on an older firewalld that doesn't carry alvr.xml yet.
  if alvr_service_known; then
    echo "  opening the ALVR service (9943-9944, permanent)…"
    $FW --permanent --add-service=alvr >/dev/null || rc=1
  else
    echo "  opening ports 9943-9944 tcp+udp (permanent)…"
    $FW --permanent --add-port=9943-9944/tcp >/dev/null || rc=1
    $FW --permanent --add-port=9943-9944/udp >/dev/null || rc=1
  fi
  # Remove any permanent blanket-open range (the reload below drops runtime ones).
  local p
  for p in $($FW --permanent --list-ports 2>/dev/null | tr ' ' '\n' \
             | grep -E '^[0-9]+-[0-9]+/(tcp|udp)$' | awk -F'[-/]' '($2-$1)>=1000{print $0}'); do
    echo "  clearing the wide-open hack: $p"
    $FW --permanent --remove-port="$p" >/dev/null || rc=1
  done
  echo "  reloading firewalld (applies the ALVR rule, drops any runtime open-everything hack)…"
  $FW --reload >/dev/null || rc=1
  return "$rc"
}

next_steps() {
  cat <<'EOF'

Firewall's ready. The rest is done by whoever's using the headset — ask nugget:

    "help me set up VR"        (the vr-setup skill walks you through it)

The short version:
  1. On the PC: install SteamVR in Steam, then install ALVR
     (it's a Steam add-on, not a normal app) and run it once.
  2. On the headset: install the ALVR app (via the ALVR launcher or SideQuest),
     open it, and — with the headset ON — click "Trust" next to it in ALVR's
     Devices tab on the PC.
  3. Both the PC and the headset must be on the SAME Wi-Fi (5 GHz is best;
     a "guest" network won't work).
  4. Older AMD card (RX 500-series): set ALVR's video codec to H.264, or the
     headset shows a black screen.

Easier alternative worth a look: WiVRn (in the Bazaar/Discover app store) does
the same wireless-VR job with less fiddling.
EOF
}

sub="${1:-doctor}"; [ $# -gt 0 ] && shift

case "$sub" in
  doctor)
    FIX=0; [ "${1:-}" = "--fix" ] && FIX=1
    if [ "$FIX" = 1 ] && [ "$(id -u)" != 0 ]; then
      echo "--fix changes the firewall, so it needs admin rights:  sudo lacos vr doctor --fix"; exit 1
    fi
    declare -a REPORT=()
    note() { REPORT+=("$1"); }
    fw_ok=1

    if fw_running; then note "PASS firewalld is running"
    else note "FAIL firewalld isn't running — the headset can't reach the PC without it"; fw_ok=0; fi

    if alvr_permanent || ports_permanent; then
      note "PASS ALVR ports (9943-9944) are open permanently (survive a reboot)"
    else
      note "FAIL ALVR ports (9943-9944) aren't open permanently — VR breaks after a restart"; fw_ok=0
    fi

    bp="$(blanket_ports)"
    if [ -n "$bp" ]; then
      note "WARN a wide-open port range is set ($(echo $bp | tr '\n' ' ')) — the 'open everything' hack; VR only needs 9943-9944"; fw_ok=0
    else
      note "PASS no wide-open port ranges — the firewall is minimal"
    fi

    if flatpak info "$ALVR_FLATPAK" >/dev/null 2>&1 || flatpak list 2>/dev/null | grep -q "$ALVR_FLATPAK"; then
      note "PASS ALVR is installed"
    else
      note "INFO ALVR isn't installed yet — ask nugget \"help me set up VR\" (not a firewall problem)"
    fi

    if command -v steam >/dev/null 2>&1 || flatpak list 2>/dev/null | grep -qi 'valvesoftware.Steam'; then
      note "PASS Steam is present (SteamVR is ALVR's runtime)"
    else
      note "WARN Steam not found — ALVR needs SteamVR, which comes from Steam"
    fi

    if lspci 2>/dev/null | grep -qiE 'Polaris|Radeon.*(RX ?5[0-9]0)'; then
      note "INFO older AMD (Polaris) GPU — set ALVR's codec to H.264 (HEVC = black screen on these cards)"
    fi
    note "INFO PC + headset must share one Wi-Fi (5 GHz best; no guest / AP-isolation)."

    echo "lacos vr doctor — $(hostname)"
    printf '  %s\n' "${REPORT[@]}"
    if [ "$FIX" != 1 ]; then
      if [ "$fw_ok" = 1 ]; then echo; echo "VR firewall looks good. 🐔🥽"; exit 0; fi
      echo; echo "Fix the firewall with:  sudo lacos vr doctor --fix    (or: sudo lacos vr setup)"; exit 1
    fi
    # --fix
    [ "$fw_ok" = 1 ] && { echo; echo "Nothing to fix. 🐔🥽"; exit 0; }
    echo; echo "── repairing the VR firewall ──"
    if fix_firewall; then echo; echo "── done — re-check: lacos vr doctor ──"; exit 0
    else echo; echo "── something didn't apply (rc≠0) — re-check: lacos vr doctor ──" >&2; exit 1; fi
    ;;

  setup)
    echo "Setting up wireless VR (ALVR) on this box…"
    if fix_firewall; then next_steps; exit 0
    else echo "Couldn't finish the firewall setup — try:  sudo lacos vr doctor --fix" >&2; exit 1; fi
    ;;

  help|-h|--help|"")
    cat <<'EOF'
lacos vr — wireless VR (ALVR) firewall + readiness  🥽

  lacos vr doctor             check the VR firewall + readiness (safe, no admin)
  sudo lacos vr doctor --fix  repair the firewall (minimal ALVR ports, permanent)
  sudo lacos vr setup         fix the firewall, then show the kid's next steps
  lacos vr help               this help

The kid coaching (install ALVR, pair the headset, tune the picture) lives in the
nugget "vr-setup" skill — ask nugget: "help me set up VR".
EOF
    ;;
  *)
    echo "unknown: lacos vr $sub — try: lacos vr help" >&2; exit 2 ;;
esac
