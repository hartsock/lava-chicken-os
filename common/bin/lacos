#!/usr/bin/env bash
# LaCOS — Lava Chicken OS control command. One friendly branded entrypoint for
# the box: status, attach the resident nugget agent, drive the agent, version.
set -euo pipefail
VERSION_FILE=/etc/lava-chicken/version
STATE=/var/lib/lava-chicken

ver() { cat "$VERSION_FILE" 2>/dev/null || echo "?"; }

find_bin() {  # locate a helper: baked (/usr/share) on Bazzite, /var on SteamOS
  local d
  for d in /usr/share/lava-chicken/bin "$STATE/bin"; do
    [ -x "$d/$1" ] && { echo "$d/$1"; return 0; }
  done
  command -v "$1" 2>/dev/null || return 1
}

usage() {
  cat <<EOF
LaCOS $(ver) — Lava Chicken OS  🐔🌋
usage: lacos <command>
  status        services + resident agent + version
  mode          show boot mode; 'sudo lacos mode console|desktop' switches it
                (console = Game Mode like a Steam Deck; desktop = normal desktop)
  attach        attach the resident nugget agent session (the "nugget" button)
  agent <cmd>   pause|resume|disable|kill|status the agent (wraps nugget-agentctl)
  setup         run the 2nd-boot setup wizard (name, Tailscale, home DNS, ...)
  doctor        check the box end-to-end; 'sudo lacos doctor --fix' repairs
  models        pull/refresh the LLM models (qwen2.5-coder + embeddings)
  apps          install/refresh the creative + gaming Flatpak apps
  version       print the OS version
  help          this help
EOF
}

case "${1:-help}" in
  status)
    echo "LaCOS $(ver) — host $(hostname)"
    for u in nugget-agent-tmux.service ollama.service sshd.service \
             lava-chicken-boot-sound.service; do
      printf '  %-30s %s\n' "$u" "$(systemctl is-active "$u" 2>/dev/null || echo unknown)"
    done
    if [ -S /run/nugget/tmux.sock ]; then echo "  nugget session               LIVE"
    else echo "  nugget session               absent"; fi
    v="$(cat /usr/share/lava-chicken/variant 2>/dev/null || echo '?')"
    case "$v" in deck) echo "  boot mode                    console (Game Mode)";;
                 stable) echo "  boot mode                    desktop";; esac
    if [ -s /var/lib/lava-chicken/firstboot.failed-steps ]; then
      echo "  !! provisioning steps FAILED: $(tr '\n' ' ' < /var/lib/lava-chicken/firstboot.failed-steps)"
      echo "     re-run each: sudo bash /usr/share/lava-chicken/provision/<step>"
    fi
    ;;
  mode)
    # Parent-friendly wrapper around `bootc switch` (#23): pick what the box
    # boots into, by name, without knowing registries or tags.
    shift
    cur="$(cat /usr/share/lava-chicken/variant 2>/dev/null || echo unknown)"
    case "$cur" in deck) curname="console (Game Mode)";; stable) curname=desktop;; *) curname="$cur";; esac
    if [ $# -eq 0 ]; then
      echo "Current mode: $curname"
      echo "Switch with:  sudo lacos mode console    (boots straight into Game Mode, like a Steam Deck)"
      echo "         or:  sudo lacos mode desktop    (boots to the normal desktop)"
      exit 0
    fi
    case "$1" in
      console|deck|game|gamemode) want=deck;  wantname="console (Game Mode)";;
      desktop|stable)             want=stable; wantname="desktop";;
      *) echo "unknown mode '$1' — use: console or desktop" >&2; exit 2;;
    esac
    command -v bootc >/dev/null 2>&1       || { echo "mode switching needs the bootc-based (Bazzite) image; this box doesn't have bootc." >&2; exit 1; }
    if [ "$want" = "$cur" ]; then echo "Already in $wantname mode — nothing to do."; exit 0; fi
    [ "$(id -u)" = 0 ] || { echo "This needs admin rights — run:  sudo lacos mode $1"; exit 1; }
    # Derive the image from what's booted so forks keep working; swap only the tag.
    img="$(bootc status --format json 2>/dev/null       | python3 -c 'import json,sys; s=json.load(sys.stdin); print(s["status"]["booted"]["image"]["image"]["image"])' 2>/dev/null || true)"
    [ -n "$img" ] || { echo "could not read the booted image from bootc status" >&2; exit 1; }
    img="${img%%@*}"; base="${img%:*}"
    echo "Switching to $wantname mode  ->  ${base}:${want}"
    bootc switch "${base}:${want}"
    echo
    echo "Done. The new mode takes effect on the next restart:"
    echo "  systemctl reboot        (or just use the power menu)"
    echo "Changed your mind? 'sudo lacos mode ${curname%% *}' switches back the same way."
    ;;
  attach)
    if a="$(find_bin attach-nugget)"; then exec "$a"
    else echo "attach-nugget not found" >&2; exit 1; fi
    ;;
  agent)
    shift
    if c="$(find_bin nugget-agentctl)"; then exec sudo "$c" "$@"
    else echo "nugget-agentctl not found" >&2; exit 1; fi
    ;;
  models)
    shift
    if m="$(find_bin lacos-pull-models)"; then exec "$m" "$@"
    else echo "lacos-pull-models not found" >&2; exit 1; fi
    ;;
  apps)
    shift
    if a="$(find_bin lacos-install-apps)"; then exec "$a" "$@"
    else echo "lacos-install-apps not found" >&2; exit 1; fi
    ;;
  setup)
    shift
    if s="$(find_bin lacos-setup)"; then exec "$s" "$@"
    else echo "lacos-setup not found" >&2; exit 1; fi
    ;;
  doctor)
    shift
    if d="$(find_bin lacos-doctor)"; then exec "$d" "$@"
    else echo "lacos-doctor not found" >&2; exit 1; fi
    ;;
  version) ver ;;
  help|-h|--help) usage ;;
  *) usage; exit 2 ;;
esac
